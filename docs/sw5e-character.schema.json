{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JethroHotep/sw5e-sheet/docs/sw5e-character.schema.json",
  "title": "SW5e Character Sheet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "character"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "character": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "level",
        "class",
        "proficiencyBonus",
        "abilities",
        "savingThrows",
        "skills",
        "combat"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "class": {
          "type": "string"
        },
        "background": {
          "type": "string"
        },
        "proficiencyBonus": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "abilities": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "str",
            "dex",
            "con",
            "int",
            "wis",
            "cha"
          ],
          "properties": {
            "str": {
              "$ref": "#/$defs/abilityScore"
            },
            "dex": {
              "$ref": "#/$defs/abilityScore"
            },
            "con": {
              "$ref": "#/$defs/abilityScore"
            },
            "int": {
              "$ref": "#/$defs/abilityScore"
            },
            "wis": {
              "$ref": "#/$defs/abilityScore"
            },
            "cha": {
              "$ref": "#/$defs/abilityScore"
            }
          }
        },
        "savingThrows": {
          "type": "object",
          "description": "Saving throw proficiency flags by ability. True means the character adds proficiency bonus to that saving throw.",
          "additionalProperties": false,
          "required": [
            "str",
            "dex",
            "con",
            "int",
            "wis",
            "cha"
          ],
          "properties": {
            "str": {
              "$ref": "#/$defs/proficiencyFlag"
            },
            "dex": {
              "$ref": "#/$defs/proficiencyFlag"
            },
            "con": {
              "$ref": "#/$defs/proficiencyFlag"
            },
            "int": {
              "$ref": "#/$defs/proficiencyFlag"
            },
            "wis": {
              "$ref": "#/$defs/proficiencyFlag"
            },
            "cha": {
              "$ref": "#/$defs/proficiencyFlag"
            }
          }
        },
        "skills": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/skill"
          }
        },
        "combat": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "armorClass",
            "speed",
            "hitPoints"
          ],
          "properties": {
            "armorClass": {
              "type": "integer",
              "minimum": 0
            },
            "initiativeBonus": {
              "type": "integer"
            },
            "speed": {
              "type": "integer",
              "minimum": 0
            },
            "hitPoints": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "max",
                "current",
                "temporary"
              ],
              "properties": {
                "max": {
                  "type": "integer",
                  "minimum": 0
                },
                "current": {
                  "type": "integer",
                  "minimum": 0
                },
                "temporary": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            },
            "techcastingDc": {
              "type": "integer",
              "minimum": 0,
              "description": "Optional override for the displayed techcasting save DC. If omitted, the app uses 8 + proficiency + INT modifier."
            }
          }
        },
        "attacks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/attack"
          }
        },
        "resources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resource"
          }
        },
        "inventory": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inventoryItem"
          }
        },
        "credits": {
          "$ref": "#/$defs/credits"
        },
        "customRolls": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/customRoll"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "abilityKey": {
      "enum": [
        "str",
        "dex",
        "con",
        "int",
        "wis",
        "cha"
      ]
    },
    "abilityScore": {
      "type": "integer",
      "minimum": 1,
      "maximum": 30
    },
    "proficiencyFlag": {
      "type": "boolean",
      "description": "True when the character is proficient and should display a PROF flag in the app."
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ability",
        "proficient"
      ],
      "properties": {
        "ability": {
          "$ref": "#/$defs/abilityKey"
        },
        "proficient": {
          "type": "boolean",
          "description": "True when the character adds proficiency bonus to this skill. Displays a PROF flag unless expertise is true."
        },
        "expertise": {
          "type": "boolean",
          "description": "True when the character adds proficiency bonus twice to this skill. Displays an EXP flag."
        },
        "bonus": {
          "type": "integer"
        }
      }
    },
    "attack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "attackAbility": {
          "$ref": "#/$defs/abilityKey"
        },
        "proficient": {
          "type": "boolean"
        },
        "attackBonus": {
          "type": "integer"
        },
        "actionType": {
          "$ref": "#/$defs/actionType"
        },
        "damage": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/damagePart"
          }
        },
        "properties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        },
        "depletes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/depletion"
          }
        },
        "depletionOptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/depletionOption"
          }
        },
        "help": {
          "$ref": "#/$defs/help"
        }
      }
    },
    "damagePart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "formula"
      ],
      "properties": {
        "formula": {
          "type": "string",
          "minLength": 1
        },
        "ability": {
          "$ref": "#/$defs/abilityKey"
        },
        "bonus": {
          "type": "integer"
        },
        "type": {
          "type": "string"
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "current",
        "max"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "current": {
          "type": "integer",
          "minimum": 0
        },
        "max": {
          "type": "integer",
          "minimum": 0
        },
        "unit": {
          "type": "string",
          "description": "Optional display unit, such as points, uses, cells, shots, days, or charges."
        },
        "restRecovery": {
          "$ref": "#/$defs/restRecovery"
        },
        "notes": {
          "type": "string"
        },
        "help": {
          "$ref": "#/$defs/help"
        }
      }
    },
    "inventoryItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string"
        },
        "quantity": {
          "type": "integer",
          "minimum": 0
        },
        "cost": {
          "type": "integer",
          "minimum": 0
        },
        "equipped": {
          "type": "boolean"
        },
        "infused": {
          "type": "boolean"
        },
        "armorClassFormula": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "depletes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/depletion"
          }
        },
        "depletionOptions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/depletionOption"
          }
        },
        "source": {
          "type": "string"
        },
        "contents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "attuned": {
          "type": "boolean"
        },
        "modifications": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "containedResources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/containedResource"
          }
        },
        "help": {
          "$ref": "#/$defs/help"
        }
      }
    },
    "credits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "starting": {
          "type": "integer",
          "minimum": 0
        },
        "spent": {
          "type": "integer",
          "minimum": 0
        },
        "remaining": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "type": "string"
        },
        "help": {
          "$ref": "#/$defs/help"
        }
      }
    },
    "customRoll": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "name",
            "formula"
          ],
          "properties": {
            "kind": {
              "enum": [
                "roll"
              ],
              "description": "Roll entries produce dice output. If omitted and formula is not 0, the app treats the entry as a roll."
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "formula": {
              "type": "string",
              "minLength": 1
            },
            "actionType": {
              "$ref": "#/$defs/actionType"
            },
            "notes": {
              "type": "string"
            },
            "depletes": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/depletion"
              }
            },
            "depletionOptions": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/depletionOption"
              }
            },
            "help": {
              "$ref": "#/$defs/help"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "id",
            "name"
          ],
          "properties": {
            "kind": {
              "const": "reference",
              "description": "Reference entries post notes without dice. Legacy entries with formula 0 are also treated as references by the app."
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "actionType": {
              "$ref": "#/$defs/actionType"
            },
            "notes": {
              "type": "string"
            },
            "depletes": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/depletion"
              }
            },
            "depletionOptions": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/depletionOption"
              }
            },
            "help": {
              "$ref": "#/$defs/help"
            }
          }
        }
      ]
    },
    "resourceRef": {
      "type": "object",
      "description": "Reference to a character-level resource, HP field, inventory item quantity, or a contained resource inside an inventory item.",
      "additionalProperties": false,
      "required": [
        "scope",
        "id"
      ],
      "properties": {
        "scope": {
          "enum": [
            "character",
            "inventoryItem",
            "hitPoints",
            "inventoryQuantity"
          ],
          "description": "character = character.resources[].id; inventoryItem = inventory[].containedResources[].id on a specific item; hitPoints = combat.hitPoints current/temporary/max; inventoryQuantity = inventory[].quantity."
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Resource id. For inventoryItem scope, this is the contained resource id. For hitPoints, use current, temporary, or max. For inventoryQuantity, this may be the inventory item id."
        },
        "itemId": {
          "type": "string",
          "minLength": 1,
          "description": "Required when scope is inventoryItem; optional alias for the inventory item id when scope is inventoryQuantity."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "scope": {
                "const": "inventoryItem"
              }
            },
            "required": [
              "scope"
            ]
          },
          "then": {
            "required": [
              "itemId"
            ]
          }
        }
      ]
    },
    "depletion": {
      "type": "object",
      "description": "A resource cost/spend/depletion caused by using a feature, item, attack, or custom action.",
      "additionalProperties": false,
      "required": [
        "target",
        "amount"
      ],
      "properties": {
        "target": {
          "$ref": "#/$defs/resourceRef"
        },
        "amount": {
          "type": "integer",
          "minimum": 1
        },
        "trigger": {
          "enum": [
            "onUse",
            "onAttack",
            "onDamageRoll",
            "onCast",
            "onActivation",
            "onEquip",
            "manual"
          ],
          "description": "When the app should offer or apply the depletion."
        },
        "prompt": {
          "type": "boolean",
          "description": "If true, the app should ask before subtracting the resource."
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "depletionOption": {
      "type": "object",
      "description": "Alternative resource payment option, such as a free feat use OR spending tech points.",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "depletes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "depletes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/depletion"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "containedResource": {
      "type": "object",
      "description": "A resource contained by an inventory item, such as a loaded power cell, battery charge, or item-specific uses.",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "current",
        "max"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "description": "Display/type tag such as power-cell, battery, charge, cartridge, dose, or use."
        },
        "unit": {
          "type": "string",
          "description": "Display unit, such as cells, charges, shots, doses, minutes, or uses."
        },
        "current": {
          "type": "integer",
          "minimum": 0
        },
        "max": {
          "type": "integer",
          "minimum": 0
        },
        "rechargeFromResourceId": {
          "type": "string",
          "description": "Optional character.resources[].id used to refill/reload this contained resource."
        },
        "restRecovery": {
          "$ref": "#/$defs/restRecovery"
        },
        "notes": {
          "type": "string"
        },
        "help": {
          "$ref": "#/$defs/help"
        }
      }
    },
    "restRecovery": {
      "enum": [
        "none",
        "short",
        "long",
        "shortOrLong"
      ],
      "description": "Controls the app's Short Rest and Long Rest buttons. none/manual consumables are not restored automatically; shortOrLong restores on either rest."
    },
    "actionType": {
      "enum": [
        "action",
        "bonusAction",
        "reaction"
      ],
      "description": "Optional action timing tag displayed by the app."
    },
    "help": {
      "type": "object",
      "description": "Detailed in-app help page content for this sheet object.",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "activation": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "heading": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "items": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "description": "SW5e character JSON schema with explicit resource depletion hooks for actions, features, inventory items, and item-contained resources such as loaded power cells."
}
